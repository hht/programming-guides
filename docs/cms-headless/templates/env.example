# Copy to implementation repo; values are per-environment (never commit secrets).
# staging/prod must both define the same variable *names*.
# Choose ONE provider per INPUTS (do not dual-SSOT two CMS vendors).

APP_ENV=development

CMS_PROVIDER=contentful
# CMS_PROVIDER=sanity
# CMS_PROVIDER=payload
# CMS_PROVIDER=self_hosted

CMS_PROJECT_OR_SPACE_ID=change-me-staging-and-prod-paired
CMS_DELIVERY_BASE_URL=https://cdn.example.com
CMS_DELIVERY_TOKEN=change-me-delivery-readonly
# Preview — server-only; never ship to public frontend bundles
CMS_PREVIEW_TOKEN=change-me-preview-server-only

# Optional: cache invalidation webhook
# CMS_WEBHOOK_SECRET=change-me-staging-and-prod-paired
# CMS_WEBHOOK_PATH=/cms/webhook

# Cache TTL seconds when not using webhook invalidation (INPUTS default 60)
CMS_DELIVERY_CACHE_TTL_SECONDS=60
