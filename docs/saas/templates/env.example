# Copy to application repo as .env.example — values never committed for staging/prod secrets.
# Pair staging + prod for every secret/URL below.

APP_ENV=development

# Shared with docs/auth — Subject from Session Gate
DATABASE_URL=postgres://user:pass@localhost:5432/app

# Tenant resolve (enable what INPUTS selects)
# TENANT_HEADER=X-Tenant-Id
# TENANT_ROOT_DOMAIN=staging.example.com
# TENANT_ROOT_DOMAIN_PROD=example.com

# Optional: bind current tenant in session/cookie (still re-check Membership every request)
# CURRENT_TENANT_COOKIE=current_tenant

# Billing (only when INPUTS §9 enabled) — provider is INPUTS choice, not guide-default-only
# BILLING_WEBHOOK_SECRET=change-me-staging-and-prod-paired
# BILLING_PROVIDER=stripe
# STRIPE_WEBHOOK_SECRET=
# STRIPE_SECRET_KEY=

# RLS session variable name must match postgres policies (default app.tenant_id)
# APP_TENANT_SETTING_KEY=app.tenant_id
