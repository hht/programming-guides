# Copy names into application repo — values never committed for staging/prod secrets.
# Pair staging + prod for every secret/URL below.
# May map to BuildConfig fields / local.properties; keep the *names* stable.

APP_ENV=development

# API (pair staging/prod)
API_BASE_URL=https://api.staging.example.com

# Optional auth (when INPUTS §5 enabled) — store tokens in EncryptedSharedPreferences / credential store
# AUTH_CLIENT_ID=
# AUTH_REDIRECT_SCHEME=

# Optional feature flags
# FEATURE_OFFLINE_CACHE=false
