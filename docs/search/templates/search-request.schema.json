{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-templates.local/search/search-request.schema.json",
  "title": "SearchRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["query"],
  "properties": {
    "query": {
      "type": "string",
      "maxLength": 200,
      "description": "Raw user search text; server parses to tsquery."
    },
    "entity": {
      "type": "string",
      "description": "Optional entity filter when API is multi-entity."
    },
    "filters": {
      "type": "object",
      "description": "Whitelist-only filters from INPUTS; unknown keys → validation error.",
      "additionalProperties": true
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "default": 20
    },
    "offset": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "cursor": {
      "type": ["string", "null"],
      "description": "Alternative to offset when INPUTS chooses cursor pagination."
    }
  }
}
