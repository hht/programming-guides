# APP_ENV=development|staging|prod
# HTTP_ADDR=:8080
# 集成测默认（与 docker-compose.test.yml.example 同文）：
# DATABASE_URL=postgres://app:app@localhost:5432/app_test?sslmode=disable
# LOG_LEVEL=info
# JWT_SECRET=              # Bearer HS256
# JWT_PUBLIC_KEY_PEM=      # Bearer RS256（PEM 全文）
# SESSION_COOKIE_NAME=sid  # 若 Session
# IdP（仅 INPUTS §6=外部 IdP；键名冻结）：
# IDP_ISSUER=
# IDP_JWKS_URL=            # 若选 JWKS
# IDP_INTROSPECTION_URL=   # 若选 introspection
# IDP_CLIENT_ID=
# IDP_CLIENT_SECRET=
