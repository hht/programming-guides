{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://programming-guides.local/email-delivery/email-message.schema.json",
  "title": "EmailMessage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message_id",
    "idempotency_key",
    "template_id",
    "template_version",
    "to",
    "from",
    "subject",
    "state"
  ],
  "properties": {
    "message_id": {
      "type": "string",
      "minLength": 1,
      "description": "Application-side primary id"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "template_id": { "type": "string", "minLength": 1 },
    "template_version": { "type": "integer", "minimum": 1 },
    "to": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "format": "email" }
    },
    "from": { "type": "string", "minLength": 1 },
    "subject": { "type": "string", "minLength": 1 },
    "body_html": { "type": "string" },
    "body_text": { "type": "string" },
    "provider_message_id": {
      "type": ["string", "null"],
      "description": "Id returned by ESP after submit"
    },
    "state": {
      "type": "string",
      "enum": [
        "composed",
        "queued",
        "submitted",
        "delivered",
        "bounced",
        "complained",
        "failed",
        "suppressed"
      ]
    },
    "last_error": { "type": ["string", "null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
