# Copy names into staging/prod secret stores — never commit real values.
# Provider: set exactly one implementation via EMAIL_PROVIDER (resend|postmark|ses|other)

APP_ENV=staging

EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM=noreply@example.com
EMAIL_WEBHOOK_SECRET=

# Amazon SES (only if EMAIL_PROVIDER=ses)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# SES_CONFIGURATION_SET=

# Async path (recommended) — align with workers-queue
# DATABASE_URL=
# WORKER_CONCURRENCY=4
# JOB_VISIBILITY_TIMEOUT_SECONDS=30
# JOB_MAX_ATTEMPTS=5
