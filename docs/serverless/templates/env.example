# Copy to implementation repo; values are per-environment (never commit secrets).
# staging/prod must both define the same variable *names*.
# Choose ONE platform per INPUTS (do not enable dual SSOT).

APP_ENV=development

# --- Cloudflare Workers (default) ---
# Secrets via `wrangler secret` / .dev.vars (gitignored); not committed.
# Example public vars (non-secret):
# PUBLIC_APP_URL=http://127.0.0.1:8787

# Wall timeout budget seconds (must match INPUTS)
FUNCTION_WALL_TIMEOUT_SECONDS=30
FUNCTION_MAX_ATTEMPTS=5
FUNCTION_BACKOFF_BASE_SECONDS=1
FUNCTION_BACKOFF_CAP_SECONDS=900

# --- OpenNext / Vercel (only if INPUTS selects) ---
# VERCEL_ENV=preview
# FUNCTION_WALL_TIMEOUT_SECONDS=10

# --- AWS Lambda (only if INPUTS selects) ---
# AWS_REGION=ap-northeast-1
# FUNCTION_WALL_TIMEOUT_SECONDS=30
