# Copy to implementation repo; values are per-environment (never commit secrets).
# staging/prod must both define the same variable *names*.

APP_ENV=development
APP_DEFAULT_LOCALE=en
# Comma-separated BCP 47 tags; must include APP_DEFAULT_LOCALE
APP_SUPPORTED_LOCALES=en,zh-CN

# Persist user locale preference (name must match detect-locale implementation)
# Next.js common: NEXT_LOCALE
# Vite SPA example:
APP_LOCALE_COOKIE=app_locale

# Optional: force locale in preview (empty = use detect order)
# APP_FORCE_LOCALE=
