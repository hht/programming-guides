{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "required": ["ok"],
      "additionalProperties": false,
      "properties": {
        "ok": { "const": true },
        "data": true
      }
    },
    {
      "type": "object",
      "required": ["ok", "code", "error"],
      "additionalProperties": false,
      "properties": {
        "ok": { "const": false },
        "code": {
          "type": "string",
          "enum": ["validation", "unauthorized", "forbidden", "conflict", "internal"]
        },
        "error": { "type": "string" },
        "fieldErrors": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  ]
}
