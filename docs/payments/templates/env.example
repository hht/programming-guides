# Copy to implementation repo; values are per-environment (never commit secrets).
# staging/prod must both define the same variable *names*.
# Choose ONE provider per INPUTS (do not dual-SSOT two providers).

APP_ENV=development

PAYMENT_PROVIDER=stripe
# PAYMENT_PROVIDER=other

PAYMENT_SECRET_KEY=change-me-staging-and-prod-paired
PAYMENT_PUBLISHABLE_KEY=change-me-staging-and-prod-paired
PAYMENT_WEBHOOK_SECRET=change-me-staging-and-prod-paired

# Public webhook URL path is app-defined; secret above must match provider endpoint.
# PAYMENT_WEBHOOK_PATH=/payments/webhook

# Optional SaaS billing bridge (docs/saas) — only when INPUTS §10 enabled
# BILLING_WEBHOOK_SECRET=  # prefer PAYMENT_WEBHOOK_SECRET as single ingress

# Stripe mapping example names (when PAYMENT_PROVIDER=stripe)
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
