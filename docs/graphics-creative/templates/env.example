# Copy to application repo as .env.example — values never committed for staging/prod secrets.
# Motion feature flags: pair staging + prod names; values not in repo.

APP_ENV=development

# Optional: disable non-critical motion in staging for A/B of degrade path
# MOTION_CRITICAL_ONLY=false

# Optional: force degrade tier (1-5) for QA; empty = normal lifecycle
# MOTION_FORCE_DEGRADE_TIER=

# Optional: log measure reminders in non-prod
# MOTION_MEASURE_REMINDER=true
