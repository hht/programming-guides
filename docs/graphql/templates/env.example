# Copy to application repo as .env.example — values never committed for staging/prod secrets.
# Pair staging + prod for every secret/URL below.

APP_ENV=development

# GraphQL HTTP
GRAPHQL_PATH=/graphql
# Public base URLs (pair staging + prod); secrets stay out of git
# GRAPHQL_URL_STAGING=https://staging.example.com/graphql
# GRAPHQL_URL_PROD=https://api.example.com/graphql

# Introspection: development may enable; staging/prod default off or controlled (INPUTS §8)
GRAPHQL_INTROSPECTION=true

# Optional persisted operations (INPUTS §12)
# GRAPHQL_PERSISTED_OPERATIONS=false

# Depth / complexity defaults (override in INPUTS §17 if needed)
# GRAPHQL_MAX_DEPTH=10

# Auth / session — align with docs/auth (Session Gate). Do not invent a second secret scheme.
SESSION_COOKIE_NAME=session
SESSION_SECRET=change-me-min-32-chars-staging-and-prod-paired
DATABASE_URL=postgres://user:pass@localhost:5432/app

# Optional Bearer (auth mode D) — not for browser localStorage primary session
# JWT_ISSUER=
# JWT_AUDIENCE=
# JWT_SECRET=
# or JWT_JWKS_URL=

# CORS when browser cross-origin (enumerate — never * with credentials)
# CORS_ORIGINS=https://staging.example.com,https://app.example.com
