# Copy to implementation repo; values are per-environment (never commit secrets).
# staging/prod must both define the same variable *names*.

APP_ENV=development

# S3-compatible endpoint (local MinIO default)
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=app-objects
S3_FORCE_PATH_STYLE=true

# Presign TTLs (seconds)
PRESIGN_PUT_TTL_SECONDS=300
PRESIGN_GET_TTL_SECONDS=60

# Object limits
OBJECT_MAX_BYTES=20971520
