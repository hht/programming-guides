# Copy to implementation repo; values are per-environment (never commit secrets).
# staging/prod must both define the same variable *names*.
# Choose ONE backend per INPUTS (do not enable both as dual SSOT).

APP_ENV=development

# --- PostgreSQL SKIP LOCKED (default when app already has PG) ---
DATABASE_URL=postgres://app:app@127.0.0.1:5432/app?sslmode=disable

# --- Redis Streams (only if INPUTS selects Streams) ---
# REDIS_URL=redis://127.0.0.1:6379/0

WORKER_CONCURRENCY=4
JOB_VISIBILITY_TIMEOUT_SECONDS=30
JOB_MAX_ATTEMPTS=5
JOB_BACKOFF_BASE_SECONDS=1
JOB_BACKOFF_CAP_SECONDS=900
