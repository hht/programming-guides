# Copy names into staging/prod secret stores — never commit real values.
# Runtime: set exactly one via INFERENCE_RUNTIME (onnx|pytorch|vllm|triton|other)

APP_ENV=staging

MODEL_ID=ticket.classify
ARTIFACT_VERSION=1.0.0
# Or digest strategy (pick one strategy repo-wide):
# ARTIFACT_VERSION=sha256:0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

ARTIFACT_URI=./artifacts/ticket.classify/1.0.0
INFERENCE_RUNTIME=onnx

INFERENCE_API_KEY=
INFERENCE_TIMEOUT_SECONDS=30
INFERENCE_MAX_IN_FLIGHT=4
INFERENCE_RATE_PER_MINUTE=60
INFERENCE_MAX_BODY_BYTES=1048576

# Optional multi-model / device
# CUDA_VISIBLE_DEVICES=0
# INFERENCE_DEVICE=cpu
