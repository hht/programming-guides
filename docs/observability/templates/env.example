# Copy to implementation repo; values are per-environment (never commit secrets).
# staging/prod must both define the same variable *names*.
# Backend may be Jaeger / Tempo / collector — do NOT require a commercial APM DSN by default.

APP_ENV=development
OTEL_SERVICE_NAME=example-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

# Optional: OTLP protocol override if your SDK supports it (http/protobuf vs grpc)
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Optional: trace sampling ratio for production (document in INPUTS §11)
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.1
