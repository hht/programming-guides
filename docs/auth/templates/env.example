# Copy to application repo as .env.example — values never committed for staging/prod secrets.
# Pair staging + prod for every secret/URL below.

APP_ENV=development

# Session
SESSION_COOKIE_NAME=session
SESSION_SECRET=change-me-min-32-chars-staging-and-prod-paired
SESSION_IDLE_TTL_SECONDS=604800
SESSION_ABSOLUTE_TTL_SECONDS=2592000

# Session store (default Postgres; Redis optional — see docs/redis/08)
DATABASE_URL=postgres://user:pass@localhost:5432/app

# Optional OAuth/OIDC (required when INPUTS mode B/C or OAuth login enabled)
# Staging/prod paired:
OAUTH_ISSUER=https://idp.example.com/
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://staging.example.com/auth/callback
# OAUTH_SCOPES=openid profile email

# Optional API/machine JWT (INPUTS mode D) — not for browser localStorage primary session
# JWT_ISSUER=
# JWT_AUDIENCE=
# JWT_SECRET=
# or JWT_JWKS_URL=

# CSRF cookie name (non-HttpOnly companion)
CSRF_COOKIE_NAME=csrf_token

# CORS (only if cross-origin browser clients; enumerate origins — never * with credentials)
# CORS_ORIGINS=https://staging.example.com,https://app.example.com
