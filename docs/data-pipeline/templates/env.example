# Copy to implementation repo; values are per-environment (never commit secrets).
# staging/prod must both define the same variable *names*.

APP_ENV=development

# --- BatchRun metadata (default: app PG) ---
DATABASE_URL=postgres://app:app@127.0.0.1:5432/app?sslmode=disable

# --- Source / Destination connection names (examples; real secrets via secret manager) ---
# SOURCE_ORDERS_DATABASE_URL=
# DESTINATION_WAREHOUSE_DATABASE_URL=
# STAGING_OBJECT_BUCKET=

PIPELINE_MAX_ATTEMPTS=5
BATCH_WINDOW=day

# --- workers-queue runner (default) ---
# Align with workers-queue INPUTS; example overrides for long batch:
WORKER_CONCURRENCY=2
JOB_VISIBILITY_TIMEOUT_SECONDS=300
JOB_MAX_ATTEMPTS=5

# --- Conditional orchestrators (only if INPUTS selects; do not dual-enable) ---
# AIRFLOW_HOME=
# DAGSTER_HOME=
