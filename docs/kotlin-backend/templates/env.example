# APP_ENV=development|staging|prod
# HTTP_ADDR=0.0.0.0:8080
# 集成测默认（与 docker-compose.test.yml.example 同文）：
# DATABASE_URL=jdbc:postgresql://localhost:5432/app_test?user=app&password=app
# LOG_LEVEL=info
# JWT_SECRET=              # Bearer HS256
# JWT_PUBLIC_KEY_PEM=      # Bearer RS256（PEM 全文）
# JWT_ISSUER=
# JWT_AUDIENCE=
# SESSION_COOKIE_NAME=sid  # 若 Session
# IDP_JWKS_URL=            # 若外部 IdP JWKS
# IDP_INTROSPECTION_URL=   # 若 introspection
# IDP_CLIENT_ID=
# IDP_CLIENT_SECRET=
