# Realtime — copy to implementation repo; values stay out of git for staging/prod secrets.

# Required (WebSocket default)
APP_ENV=development
REALTIME_WS_URL=ws://localhost:8080/realtime

# Optional SSE (INPUTS must document why)
# REALTIME_SSE_URL=http://localhost:8080/realtime/sse

# Optional multi-instance fan-out (align docs/redis)
# REDIS_URL=redis://localhost:6379/0

# Heartbeat / reconnect (defaults; override only with INPUTS)
REALTIME_HEARTBEAT_INTERVAL_S=25
REALTIME_HEARTBEAT_TIMEOUT_S=60
REALTIME_RECONNECT_INITIAL_MS=1000
REALTIME_RECONNECT_MAX_MS=30000

# Backpressure
REALTIME_OUTBOX_MAX_MESSAGES=256
REALTIME_OUTBOX_MAX_BYTES=1048576
