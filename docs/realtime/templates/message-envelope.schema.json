{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-templates.local/realtime/message-envelope.schema.json",
  "title": "RealtimeMessageEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["v", "type"],
  "properties": {
    "v": { "type": "integer", "const": 1 },
    "type": {
      "type": "string",
      "enum": [
        "hello",
        "auth",
        "subscribe",
        "unsubscribe",
        "subscribed",
        "unsubscribed",
        "event",
        "ack",
        "ping",
        "pong",
        "error"
      ]
    },
    "channel": { "type": "string", "minLength": 1, "maxLength": 256 },
    "id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "event_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "payload": { "type": ["object", "array", "string", "number", "boolean", "null"] },
    "ts": { "type": "string", "format": "date-time" },
    "conn_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "heartbeat_interval_s": { "type": "integer", "minimum": 1 },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "AUTH_REQUIRED",
            "FORBIDDEN_CHANNEL",
            "SUBSCRIBE_REJECTED",
            "BACKPRESSURE",
            "PROTOCOL_ERROR",
            "HEARTBEAT_TIMEOUT",
            "STORE_UNAVAILABLE"
          ]
        },
        "message": { "type": "string", "maxLength": 512 }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "type": { "const": "subscribe" } },
        "required": ["type"]
      },
      "then": { "required": ["channel"] }
    },
    {
      "if": {
        "properties": { "type": { "const": "event" } },
        "required": ["type"]
      },
      "then": { "required": ["channel", "event_id", "payload"] }
    },
    {
      "if": {
        "properties": { "type": { "const": "ack" } },
        "required": ["type"]
      },
      "then": { "required": ["event_id"] }
    },
    {
      "if": {
        "properties": { "type": { "const": "error" } },
        "required": ["type"]
      },
      "then": { "required": ["error"] }
    }
  ]
}
